# Nightflux Environment Configuration Example
# Copy this file to .env and adjust the values for your setup

# Nightscout Settings (required)
NIGHTFLUX_NIGHTSCOUT_URL=https://your-nightscout-instance.example.com
NIGHTFLUX_NIGHTSCOUT_TOKEN=your-nightscout-api-token

# InfluxDB Settings (required)
NIGHTFLUX_INFLUXDB_URL=http://localhost:8086
NIGHTFLUX_INFLUXDB_ORG=your-org-name
NIGHTFLUX_INFLUXDB_BUCKET=nightscout-data
NIGHTFLUX_INFLUXDB_TOKEN=your-influxdb-token

# Scheduling (required)
# This example runs once every hour (at minute 0)
NIGHTFLUX_CRON_SCHEDULE=0 * * * *

# Write logs to a file instead of stdout (optional)
# NIGHTFLUX_LOGFILE=/path/to/nightflux.log

# NIGHTFLUX_LOGLEVEL=info # debug, info, warn or error
# NIGHTFLUX_TIMEZONE=UTC # Default is local timezone

# Uncomment to run only once and exit
#NIGHTFLUX_RUN_ONCE=1